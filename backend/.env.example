# ============================================
# 校园智能助手 — 环境配置模板
# 复制为 .env 并填入真实值
# ============================================

# App
APP_NAME=Campus AI Assistant
APP_VERSION=2.0.0
DEBUG=true

# Database (必填)
DATABASE_URL=mysql+pymysql://root:你的密码@localhost:3306/campus_assistant?charset=utf8mb4

# JWT (必填，随机字符串即可)
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# AI Provider — 选一个: mock / deepseek / openai
AI_PROVIDER=mock

# OpenAI (如使用)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek (如使用)
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Embedding
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_CHUNK_SIZE=1500
EMBEDDING_CHUNK_OVERLAP=200

# Parser
PARSER_MAX_CONTENT_LENGTH=32000

# RAG
RAG_TOP_K=5
RAG_THRESHOLD=0.15

# Vector DB — mock / chroma
VECTOR_DB=mock
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=campus_knowledge

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_TYPES=pdf,docx,txt,md,csv,pptx

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION_DAYS=7
